// ============================================================
// KANAK SETU — COMPLETE DATABASE SCHEMA
// ============================================================
// Precision: money in paise (Int), gold in milligrams (Decimal(18,4))
// All financial/gold records are immutable (append-only via audit log)
// Soft delete via deletedAt where needed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== USER & AUTH =====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  role          UserRole  @default(DONOR)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  donorProfile       DonorProfile?
  institutionProfile InstitutionProfile?
  auditLogs          AuditLog[]
  sessions           Session[]

  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PhoneOtpChallenge {
  id          String   @id @default(cuid())
  phone       String
  purpose     String   // DONOR_LOGIN
  otpHash     String
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  createdAt   DateTime @default(now())

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN_OPS
  COMPLIANCE_ADMIN
  FINANCE_ADMIN
  INSTITUTION_ADMIN
  INSTITUTION_STAFF
  DONOR
  AUDITOR
}

// ===================== DONOR =====================

model DonorProfile {
  id          String         @id @default(cuid())
  userId      String         @unique
  firstName   String
  lastName    String
  profession  String?
  dateOfBirth DateTime?
  pan         String?
  kycStatus   DonorKycStatus @default(UNVERIFIED)
  address     String?
  city        String?
  state       String?
  pincode     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  donations Donation[]
  kycDocs   DonorKycDoc[]

  @@index([kycStatus])
}

enum DonorKycStatus {
  UNVERIFIED
  BASIC
  PENDING_KYC
  VERIFIED
  FLAGGED
  BLOCKED
}

model DonorKycDoc {
  id           String   @id @default(cuid())
  donorId      String
  docType      String   // PAN_CARD, AADHAAR, etc
  fileUrl      String
  verifiedAt   DateTime?
  verifiedBy   String?
  createdAt    DateTime @default(now())

  donor DonorProfile @relation(fields: [donorId], references: [id])
}

// ===================== INSTITUTION =====================

model InstitutionProfile {
  id                String            @id @default(cuid())
  userId            String            @unique
  legalName         String
  publicName        String
  type              InstitutionType
  status            InstitutionStatus @default(DRAFT)
  registrationNo    String?
  pan               String?
  gst               String?
  has80G            Boolean           @default(false)
  cert80GNumber     String?
  cert80GExpiry     DateTime?
  description       String?
  logoUrl           String?
  websiteUrl        String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  pincode           String?
  authorizedSignatory String?
  signatoryDesignation String?
  signatoryPhone    String?
  signatoryEmail    String?
  publicPageSlug    String?           @unique
  upiId             String?
  faithTradition    String?
  terminologyDonationLabel String?
  terminologyDonorLabel String?
  sacredCalendarHighlights Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user              User                @relation(fields: [userId], references: [id])
  documents         InstitutionDoc[]
  bankDetails       InstitutionBank[]
  branches          InstitutionBranch[]
  spiritualFunctions SpiritualFunction[]
  institutionTasks  InstitutionTask[]
  metricsDaily      InstitutionMetricsDaily[]
  campaigns         Campaign[]
  donations         Donation[]
  ledgerEntries     GoldLedgerEntry[]
  redemptions       RedemptionRequest[]
  adminReviews      AdminReview[]

  @@index([status])
  @@index([type])
}

enum InstitutionType {
  TRUST
  NGO
  RELIGIOUS
  FOUNDATION
  CORPORATE_CSR
}

enum InstitutionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

model InstitutionDoc {
  id            String   @id @default(cuid())
  institutionId String
  docType       String   // TRUST_DEED, PAN_CARD, 80G_CERT, REGISTRATION, etc
  fileName      String
  fileUrl       String
  uploadedAt    DateTime @default(now())

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])
}

model InstitutionBank {
  id             String   @id @default(cuid())
  institutionId  String
  accountName    String
  accountNumber  String
  ifsc           String
  bankName       String
  isPrimary      Boolean  @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])
}

model AdminReview {
  id            String   @id @default(cuid())
  institutionId String
  reviewerId    String
  action        String   // APPROVE, REJECT, SUSPEND, REQUEST_INFO
  notes         String?
  fromStatus    InstitutionStatus
  toStatus      InstitutionStatus
  createdAt     DateTime @default(now())

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])
}

// ===================== CAMPAIGN =====================

model Campaign {
  id            String   @id @default(cuid())
  institutionId String
  name          String
  description   String?
  isActive      Boolean  @default(true)
  targetAmountPaise Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])
  donations   Donation[]
}

// ===================== DONATION =====================

model Donation {
  id              String         @id @default(cuid())
  donationRef     String         @unique @default(cuid()) // public reference
  donorId         String
  institutionId   String
  campaignId      String?
  amountPaise     Int            // amount in paise
  goldQuantityMg  Decimal?       @db.Decimal(18, 4) // milligrams allocated
  goldPricePerGramPaise Int?     // price snapshot at time of order
  status          DonationStatus @default(INITIATED)
  idempotencyKey  String?        @unique
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  donor        DonorProfile       @relation(fields: [donorId], references: [id])
  institution  InstitutionProfile @relation(fields: [institutionId], references: [id])
  campaign     Campaign?          @relation(fields: [campaignId], references: [id])
  payment      PaymentTransaction?
  vendorOrder  VendorOrder?
  certificates Certificate[]
  merkleLeaf   MerkleLeaf?
  spiritualContributions SpiritualFunctionContribution[]

  @@index([status])
  @@index([donorId])
  @@index([institutionId])
  @@index([createdAt])
}

model InstitutionBranch {
  id            String   @id @default(cuid())
  institutionId String
  name          String
  city          String?
  state         String?
  latitude      Decimal? @db.Decimal(10, 6)
  longitude     Decimal? @db.Decimal(10, 6)
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])

  @@index([institutionId])
}

model SpiritualFunction {
  id              String                @id @default(cuid())
  institutionId   String
  name            String
  functionType    SpiritualFunctionType
  status          SpiritualFunctionStatus @default(ACTIVE)
  frequency       String?
  nextDate        DateTime?
  description     String?
  city            String?
  state           String?
  isPublic        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  institution  InstitutionProfile @relation(fields: [institutionId], references: [id])
  tasks        InstitutionTask[]
  contributions SpiritualFunctionContribution[]

  @@index([institutionId, status])
}

enum SpiritualFunctionType {
  PUJA
  SEVA
  FESTIVAL
  COMMUNITY_SERVICE
  EDUCATION
  HEALTH
  OTHER
}

enum SpiritualFunctionStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model SpiritualFunctionContribution {
  id                  String   @id @default(cuid())
  functionId          String
  donationId          String
  attributedAmountPaise Int
  createdAt           DateTime @default(now())

  spiritualFunction SpiritualFunction @relation(fields: [functionId], references: [id])
  donation         Donation          @relation(fields: [donationId], references: [id])

  @@index([functionId])
  @@index([donationId])
  @@unique([functionId, donationId])
}

model InstitutionTask {
  id              String              @id @default(cuid())
  institutionId   String
  functionId      String?
  title           String
  taskType        InstitutionTaskType
  status          InstitutionTaskStatus @default(TODO)
  dueDate         DateTime?
  assigneeName    String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])
  spiritualFunction SpiritualFunction? @relation(fields: [functionId], references: [id])

  @@index([institutionId, status])
}

enum InstitutionTaskType {
  PRE_EVENT
  EVENT_DAY
  POST_EVENT
  DONOR_FOLLOWUP
  COMPLIANCE
  OTHER
}

enum InstitutionTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

model InstitutionMetricsDaily {
  id                   String   @id @default(cuid())
  institutionId        String
  metricDate           DateTime
  totalDonations       Int      @default(0)
  totalAmountPaise     Int      @default(0)
  activeDonors         Int      @default(0)
  repeatDonors         Int      @default(0)
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])

  @@index([institutionId, metricDate])
  @@unique([institutionId, metricDate])
}

enum DonationStatus {
  INITIATED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  UNDER_REVIEW
  VENDOR_ORDER_PLACED
  GOLD_ALLOCATED
  COMPLETED
  BATCHED
  ANCHORED
  PAYMENT_FAILED
  VENDOR_FAILED
  DISPUTED
  REFUNDED
  CANCELLED
}

// ===================== PAYMENT =====================

model PaymentTransaction {
  id                String        @id @default(cuid())
  donationId        String        @unique
  provider          PaymentProvider
  providerOrderId   String?
  providerPaymentId String?
  amountPaise       Int
  status            PaymentStatus @default(CREATED)
  providerData      Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  donation Donation       @relation(fields: [donationId], references: [id])
  events   PaymentEvent[]

  @@index([providerOrderId])
  @@index([status])
}

enum PaymentProvider {
  RAZORPAY
  PAYU
  MOCK
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  SETTLED
  FAILED
  DISPUTED
  REFUND_INITIATED
  REFUNDED
}

model PaymentEvent {
  id              String   @id @default(cuid())
  transactionId   String
  eventType       String // webhook event type
  externalEventId String? // provider event id when present (dedupe in application layer)
  payload         Json
  signature       String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  transaction PaymentTransaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([transactionId, externalEventId])
}

// ===================== VENDOR ORDER =====================

model VendorOrder {
  id              String           @id @default(cuid())
  donationId      String           @unique
  vendor          GoldVendor
  vendorOrderRef  String?
  goldQuantityMg  Decimal?         @db.Decimal(18, 4)
  pricePerGramPaise Int?
  status          VendorOrderStatus @default(CREATED)
  vendorData      Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  donation Donation @relation(fields: [donationId], references: [id])
  events   VendorEvent[]

  @@index([status])
  @@index([vendorOrderRef])
}

model VendorEvent {
  id            String   @id @default(cuid())
  vendorOrderId String
  eventType     String
  payload       Json
  createdAt     DateTime @default(now())

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id])

  @@index([vendorOrderId])
}

enum GoldVendor {
  MMTC_PAMP
  SAFEGOLD
  AUGMONT
  MOCK
}

enum VendorOrderStatus {
  CREATED
  SUBMITTED
  CONFIRMED
  ALLOCATED
  FAILED
  REVERSED
}

// ===================== GOLD LEDGER =====================

model GoldLedgerEntry {
  id             String          @id @default(cuid())
  institutionId  String
  donationId     String?
  entryType      LedgerEntryType
  goldQuantityMg Decimal         @db.Decimal(18, 4)
  balanceAfterMg Decimal         @db.Decimal(18, 4)
  description    String?
  approvedBy     String?
  createdAt      DateTime        @default(now())

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])

  @@index([institutionId])
  @@index([createdAt])
}

enum LedgerEntryType {
  CREDIT
  DEBIT
  REVERSAL
  ADJUSTMENT
}

// ===================== REDEMPTION =====================

model RedemptionRequest {
  id              String           @id @default(cuid())
  institutionId   String
  goldQuantityMg  Decimal          @db.Decimal(18, 4)
  status          RedemptionStatus @default(REQUESTED)
  notes           String?
  reviewedBy      String?
  reviewNotes     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  institution InstitutionProfile @relation(fields: [institutionId], references: [id])

  @@index([status])
}

enum RedemptionStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

// ===================== CERTIFICATE =====================

model Certificate {
  id             String            @id @default(cuid())
  serialNumber   String            @unique
  donationId     String
  type           CertificateType
  status         CertificateStatus @default(PENDING)
  fileUrl        String?
  verificationRef String           @unique @default(cuid())
  qrData         String?
  issuedAt       DateTime?
  revokedAt      DateTime?
  revokedReason  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  donation Donation @relation(fields: [donationId], references: [id])

  @@index([donationId])
  @@index([type])
}

enum CertificateType {
  DONATION_RECEIPT
  BLOCKCHAIN_PROOF
  TAX_80G
}

enum CertificateStatus {
  PENDING
  GENERATED
  ISSUED
  REVOKED
  GENERATION_FAILED
}

// ===================== MERKLE / BLOCKCHAIN =====================

model MerkleBatch {
  id            String           @id @default(cuid())
  batchNumber   Int              @unique @default(autoincrement())
  status        MerkleBatchStatus @default(COLLECTING)
  merkleRoot    String?
  leafCount     Int              @default(0)
  sealedAt      DateTime?
  anchoredAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  leaves  MerkleLeaf[]
  anchor  BlockchainAnchor?

  @@index([status])
}

enum MerkleBatchStatus {
  COLLECTING
  SEALED
  ANCHORING
  ANCHORED
  ANCHOR_FAILED
}

model MerkleLeaf {
  id           String   @id @default(cuid())
  batchId      String
  donationId   String   @unique
  leafIndex    Int
  leafHash     String
  proofPath    Json?    // stored after tree is built
  createdAt    DateTime @default(now())

  batch    MerkleBatch @relation(fields: [batchId], references: [id])
  donation Donation    @relation(fields: [donationId], references: [id])

  @@index([batchId])
}

model BlockchainAnchor {
  id           String   @id @default(cuid())
  batchId      String   @unique
  network      String   // polygon_amoy, polygon_mainnet
  txHash       String?
  contractAddr String?
  merkleRoot   String
  gasUsed      String?
  blockNumber  Int?
  status       String   @default("PENDING") // PENDING, CONFIRMED, FAILED
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batch MerkleBatch @relation(fields: [batchId], references: [id])
}

// ===================== AUDIT LOG =====================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String   // table/model name
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ===================== NOTIFICATION =====================

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String?
  channel   String   // EMAIL, SMS, WHATSAPP, IN_APP
  type      String   // template name
  recipient String
  subject   String?
  body      String?
  status    String   @default("QUEUED") // QUEUED, SENT, FAILED
  sentAt    DateTime?
  error     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// ===================== RECONCILIATION =====================

model ReconciliationRecord {
  id           String   @id @default(cuid())
  donationId   String?
  type         String   // PAYMENT_VENDOR, VENDOR_LEDGER, BATCH_ANCHOR
  status       String   @default("PENDING") // PENDING, MATCHED, MISMATCH, RESOLVED
  details      Json?
  resolvedBy   String?
  resolvedAt   DateTime?
  resolvedNote String?
  createdAt    DateTime @default(now())

  @@index([status])
  @@index([type])
}

// ===================== SYSTEM CONFIG =====================

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json
  updatedAt DateTime @updatedAt
}

// ===================== WEBHOOK INGEST (idempotency) =====================

model WebhookDelivery {
  id             String                @id @default(cuid())
  provider       String
  idempotencyKey String                @unique
  payload        Json
  status         WebhookDeliveryStatus @default(RECEIVED)
  httpStatus     Int?
  errorMessage   String?
  processedAt    DateTime?
  createdAt      DateTime              @default(now())

  @@index([provider])
  @@index([status])
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSED
  DUPLICATE
  FAILED
}

// ===================== OUTBOX / EVENT PROCESSING =====================

model OutboxEvent {
  id            String   @id @default(cuid())
  eventType     String
  aggregateId   String
  aggregateType String
  payload       Json
  status        String   @default("pending") // pending | processing | delivered | failed
  attempts      Int      @default(0)
  lastAttemptAt DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId, aggregateType])
}

model OutboxDeadLetter {
  id          String   @id @default(cuid())
  originalId  String
  eventType   String
  aggregateId String
  aggregateType String
  payload     Json
  failReason  String
  attempts    Int
  dismissedAt DateTime?
  createdAt   DateTime @default(now())
}

// ===================== ADMIN / SUPPORT =====================

model AdminNote {
  id        String   @id @default(cuid())
  entity    String
  entityId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

model OperatorActionLog {
  id         String   @id @default(cuid())
  actionType String
  operatorId String
  targetId   String
  createdAt  DateTime @default(now())

  @@index([actionType, createdAt])
  @@index([operatorId, createdAt])
}

model SupportFlag {
  id         String    @id @default(cuid())
  targetType String
  targetId   String
  reason     String
  severity   String    @default("MEDIUM")
  status     String    @default("OPEN")
  createdBy  String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([targetType, targetId])
  @@index([status])
}

model CertificateTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  type      CertificateType
  htmlBody  String   @db.Text
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== AGRO INTELLIGENCE =====================

model AgroCommodity {
  id                   String   @id @default(cuid())
  code                 String   @unique
  name                 String
  category             String // fruit, vegetable
  defaultShelfLifeDays Int
  createdAt            DateTime @default(now())

  mandiPrices      AgroMandiPrice[]
  qualitySpecs     AgroQualitySpec[]
  storageProfiles  AgroStorageProfile[]
  recommendations  AgroRecommendation[]
}

model AgroMarket {
  id        String   @id @default(cuid())
  name      String
  region    String
  type      AgroMarketType
  createdAt DateTime @default(now())

  mandiPrices AgroMandiPrice[]

  @@index([region, type])
}

enum AgroMarketType {
  MANDI
  WHOLESALE
  RETAIL
  EXPORT_HUB
}

model AgroMandiPrice {
  id          String   @id @default(cuid())
  commodityId String
  marketId    String
  priceMin    Decimal  @db.Decimal(12, 2)
  priceMax    Decimal  @db.Decimal(12, 2)
  priceModal  Decimal  @db.Decimal(12, 2)
  unit        String   @default("INR_PER_KG")
  observedAt  DateTime
  source      String
  createdAt   DateTime @default(now())

  commodity AgroCommodity @relation(fields: [commodityId], references: [id])
  market    AgroMarket    @relation(fields: [marketId], references: [id])

  @@index([commodityId, marketId, observedAt])
}

model AgroWeatherSnapshot {
  id           String   @id @default(cuid())
  region       String
  forecastDate DateTime
  maxTempC     Decimal? @db.Decimal(5, 2)
  minTempC     Decimal? @db.Decimal(5, 2)
  humidityPct  Decimal? @db.Decimal(5, 2)
  rainfallMm   Decimal? @db.Decimal(8, 2)
  riskLevel    AgroRiskLevel
  source       String
  createdAt    DateTime @default(now())

  @@index([region, forecastDate])
}

enum AgroRiskLevel {
  LOW
  MEDIUM
  HIGH
}

model AgroQualitySpec {
  id          String   @id @default(cuid())
  commodityId String
  grade       String // A, B, C
  parameter   String
  minValue    String?
  maxValue    String?
  checklistNote String?
  createdAt   DateTime @default(now())

  commodity AgroCommodity @relation(fields: [commodityId], references: [id])

  @@index([commodityId, grade])
}

model AgroStorageProfile {
  id             String   @id @default(cuid())
  commodityId    String
  mode           AgroStorageMode
  tempRange      String?
  humidityRange  String?
  maxDays        Int
  spoilageRiskNote String?
  createdAt      DateTime @default(now())

  commodity AgroCommodity @relation(fields: [commodityId], references: [id])

  @@index([commodityId, mode])
}

enum AgroStorageMode {
  COLD
  DRY
}

model AgroLogisticsQuote {
  id                String   @id @default(cuid())
  sourceRegion      String
  destinationRegion String
  vehicleType       String
  estimatedCostInr  Decimal  @db.Decimal(12, 2)
  transitHours      Int
  coldChainSupported Boolean @default(false)
  observedAt        DateTime
  createdAt         DateTime @default(now())

  @@index([sourceRegion, destinationRegion, observedAt])
}

model AgroRecommendation {
  id                 String   @id @default(cuid())
  commodityId        String
  sourceRegion       String
  targetMarket       String
  action             AgroRecommendationAction
  confidence         Decimal  @db.Decimal(4, 3)
  expectedMarginMin  Decimal? @db.Decimal(12, 2)
  expectedMarginMax  Decimal? @db.Decimal(12, 2)
  riskFlags          Json
  assumptions        Json
  payload            Json
  validUntil         DateTime
  createdByAgent     String
  createdAt          DateTime @default(now())

  commodity AgroCommodity @relation(fields: [commodityId], references: [id])
  outcomes  AgroRecommendationOutcome[]

  @@index([commodityId, createdAt, validUntil])
}

enum AgroRecommendationAction {
  BUY
  SELL
  HOLD
}

model AgroRecommendationOutcome {
  id               String   @id @default(cuid())
  recommendationId String
  executed         Boolean  @default(false)
  executedQtyTons  Decimal? @db.Decimal(12, 3)
  realizedBuyAvg   Decimal? @db.Decimal(12, 2)
  realizedSellAvg  Decimal? @db.Decimal(12, 2)
  realizedMargin   Decimal? @db.Decimal(12, 2)
  spoilagePct      Decimal? @db.Decimal(5, 2)
  notes            String?
  recordedAt       DateTime @default(now())

  recommendation AgroRecommendation @relation(fields: [recommendationId], references: [id])

  @@index([recommendationId, recordedAt])
}

model AgroSeoContentJob {
  id                String   @id @default(cuid())
  topic             String
  targetPersona     String
  primaryKeyword    String
  secondaryKeywords Json
  status            AgroSeoStatus @default(PLANNED)
  url               String?
  impressions       Int      @default(0)
  clicks            Int      @default(0)
  createdAt         DateTime @default(now())
}

enum AgroSeoStatus {
  PLANNED
  DRAFTED
  PUBLISHED
  MEASURED
}
