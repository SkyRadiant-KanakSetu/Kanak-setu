{
  "name": "@kanak-setu/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "bash ../../scripts/prisma-generate.sh && tsc",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "test:integration:setup": "tsx src/__tests__/setupPrisma.ts",
    "test:integration": "npm run test:integration:setup && tsx --test --test-concurrency=1 src/__tests__/**/*.test.ts"
  },
  "dependencies": {
    "@kanak-setu/blockchain": "*",
    "@kanak-setu/config": "*",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ethers": "^6.11.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "keccak256": "^1.0.6",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.12.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "prisma": "5.22.0",
    "supertest": "^7.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
