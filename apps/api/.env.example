# Copy to .env for local development (see monorepo README).
# Production uses infra/prod/.env.production on the VPS.

# Server port — must not conflict with other services on the same host.
# Default in code: 4100. Another product on a shared VPS may use 4000; do not collide.
PORT=4100

# PostgreSQL (required)
DATABASE_URL=postgresql://user:password@localhost:5432/kanak_setu

# Redis — rate limiting and shared store when set.
# Example local: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# JWT and app secrets (min 32 chars for JWT_SECRET)
JWT_SECRET=change-me-minimum-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

NODE_ENV=development
