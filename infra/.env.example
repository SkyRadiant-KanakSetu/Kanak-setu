# ============================================================
# KANAK SETU — ENVIRONMENT VARIABLES
# ============================================================

# --- DATABASE ---
DATABASE_URL=postgresql://kanak:kanak_dev_pwd@localhost:5432/kanak_setu

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- APP ---
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
DONOR_WEB_URL=http://localhost:3000
INSTITUTION_WEB_URL=http://localhost:3001
ADMIN_WEB_URL=http://localhost:3002

# --- AUTH ---
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# --- PAYMENT GATEWAY ---
PAYMENT_PROVIDER=MOCK
ALLOW_MOCK_PAYMENT_SIMULATION=1
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=

# --- GOLD VENDOR ---
GOLD_VENDOR=MOCK
MMTC_API_URL=
MMTC_API_KEY=
SAFEGOLD_API_URL=
SAFEGOLD_API_KEY=
AUGMONT_API_URL=
AUGMONT_API_KEY=

# --- BLOCKCHAIN ---
BHARATCHAIN_RPC_URL=https://rpc.bharatchain.org
BLOCKCHAIN_RPC_URL=https://rpc.bharatchain.org
NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE_URL=https://explorer.bharatchain.org/tx
ANCHOR_PRIVATE_KEY=
ANCHOR_CONTRACT_ADDRESS=
CHAIN_ID=2410
CHAIN_NETWORK=bharatchain_mainnet

# --- EMAIL ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@kanaksetu.in

# --- SMS ---
SMS_PROVIDER=
SMS_API_KEY=

# --- FILE STORAGE ---
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- CRON ---
MERKLE_BATCH_CRON=0 */6 * * *
RECONCILIATION_CRON=0 2 * * *

# --- MISC ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
