kanaksetu.com {
  encode gzip
  reverse_proxy 127.0.0.1:3000
}

www.kanaksetu.com {
  redir https://kanaksetu.com{uri}
}

institution.kanaksetu.com {
  encode gzip
  reverse_proxy 127.0.0.1:3001
}

admin.kanaksetu.com {
  encode gzip
  reverse_proxy 127.0.0.1:3002
}

api.kanaksetu.com {
  encode gzip
  # Must match kanak-api listen port (same as PORT in infra/prod/.env.production).
  # Do not default to 4000: another stack often binds 4000 (wrong HTML from a different app).
  # Set KANAK_API_PORT for the Caddy process: sudo APP_DIR=/opt/kanak-setu bash scripts/prod/sync-caddy-kanak-api-port.sh
  reverse_proxy 127.0.0.1:{$KANAK_API_PORT}
}
