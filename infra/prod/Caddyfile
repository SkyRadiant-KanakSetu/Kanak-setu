kanaksetu.com {
  encode gzip
  reverse_proxy 127.0.0.1:3000
}

www.kanaksetu.com {
  redir https://kanaksetu.com{uri}
}

institution.kanaksetu.com {
  encode gzip
  reverse_proxy 127.0.0.1:3001
}

admin.kanaksetu.com {
  encode gzip
  reverse_proxy 127.0.0.1:3002
}

api.kanaksetu.com {
  encode gzip
  # Must match kanak-api listen port (PORT / PM2). On VPS: export KANAK_API_PORT=4100 for systemd/caddy if not 4000.
  reverse_proxy 127.0.0.1:{$KANAK_API_PORT:4000}
}
