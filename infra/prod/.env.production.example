# --- Runtime ---
NODE_ENV=production
# API bind port (must match Caddy api.kanaksetu.com: set KANAK_API_PORT in Caddy env to the same value — see infra/prod/Caddyfile).
PORT=4100

# --- Database / Redis ---
DATABASE_URL=postgresql://kanak:CHANGE_ME@localhost:5432/kanak_setu
# API: shared rate limits across multiple `kanak-api` instances. Optional for single-VPS; recommended when load-balancing APIs.
REDIS_URL=redis://localhost:6379

# --- Public URLs ---
API_BASE_URL=https://api.kanaksetu.com
DONOR_WEB_URL=https://kanaksetu.com
INSTITUTION_WEB_URL=https://institution.kanaksetu.com
ADMIN_WEB_URL=https://admin.kanaksetu.com

# Institution portal: base URL of donor site for QR codes (https://kanaksetu.com). Local dev: http://localhost:3000
NEXT_PUBLIC_DONOR_SITE_URL=https://kanaksetu.com

# Browser → API (baked in at `next build`; avoids broken Next rewrites to localhost in some VPS setups).
# Must stay in sync with CORS_ORIGINS and your api subdomain.
NEXT_PUBLIC_API_BASE_URL=https://api.kanaksetu.com/api/v1

# --- Auth ---
JWT_SECRET=CHANGE_TO_STRONG_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12
OPENAI_API_KEY=
OPENAI_ADMIN_ASSISTANT_MODEL=gpt-4o

# --- Integrations ---
SENTRY_DSN_API=
SENTRY_DSN_ADMIN=
SENTRY_DSN_DONOR=
SENTRY_DSN_INSTITUTION=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

PAYMENT_PROVIDER=MOCK
# LIVE_SPOT = indicative ₹/g from CoinGecko (PAXG/XAUT); MOCK = fixed demo rate
GOLD_VENDOR=LIVE_SPOT
GOLD_QUOTE_CACHE_TTL_MS=90000
GOLD_INDICATIVE_FALLBACK_PAISE=720000
ALLOW_MOCK_PAYMENT_SIMULATION=0
RUN_DB_SEED=0

# --- Blockchain ---
# Use Amoy testnet by default. For mainnet set:
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/<API_KEY>
# CHAIN_ID=137
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
ANCHOR_PRIVATE_KEY=
ANCHOR_CONTRACT_ADDRESS=
CHAIN_ID=80002
# Set to 1 to allow anchoring, 0 to hard-disable all on-chain writes.
ENABLE_BLOCKCHAIN_ANCHORING=1

# --- CORS ---
CORS_ORIGINS=https://kanaksetu.com,https://www.kanaksetu.com,https://institution.kanaksetu.com,https://admin.kanaksetu.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
