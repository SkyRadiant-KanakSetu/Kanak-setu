# --- Runtime ---
NODE_ENV=production
PORT=4000

# --- Database / Redis ---
DATABASE_URL=postgresql://kanak:CHANGE_ME@localhost:5432/kanak_setu
REDIS_URL=redis://localhost:6379

# --- Public URLs ---
API_BASE_URL=https://api.kanaksetu.com
DONOR_WEB_URL=https://kanaksetu.com
INSTITUTION_WEB_URL=https://institution.kanaksetu.com
ADMIN_WEB_URL=https://admin.kanaksetu.com

# --- Auth ---
JWT_SECRET=CHANGE_TO_STRONG_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# --- Integrations ---
PAYMENT_PROVIDER=MOCK
GOLD_VENDOR=MOCK
ALLOW_MOCK_PAYMENT_SIMULATION=0
RUN_DB_SEED=0

# --- Blockchain ---
BHARATCHAIN_RPC_URL=https://rpc.bharatchain.org
BLOCKCHAIN_RPC_URL=https://rpc.bharatchain.org
NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE_URL=https://explorer.bharatchain.org/tx
ANCHOR_PRIVATE_KEY=
ANCHOR_CONTRACT_ADDRESS=
CHAIN_ID=2410
CHAIN_NETWORK=bharatchain_mainnet

# --- CORS ---
CORS_ORIGINS=https://kanaksetu.com,https://www.kanaksetu.com,https://institution.kanaksetu.com,https://admin.kanaksetu.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
