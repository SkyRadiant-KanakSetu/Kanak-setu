{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@kanak-setu/shared-types": ["packages/shared-types/src"],
      "@kanak-setu/validators": ["packages/validators/src"],
      "@kanak-setu/sdk": ["packages/sdk/src"],
      "@kanak-setu/ui": ["packages/ui/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
